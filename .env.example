# Get your API key here - https://e2b.dev/
E2B_API_KEY=

# OpenAI API Key
OPENAI_API_KEY=

# Other providers
ANTHROPIC_API_KEY=
GROQ_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_VERTEX_CREDENTIALS=
MISTRAL_API_KEY=
XAI_API_KEY=

# Morph Apply (code editing) - https://morphllm.com/dashboard/api-keys
MORPH_API_KEY=

### Optional env vars

# Domain of the site
NEXT_PUBLIC_SITE_URL=

# Rate limit
RATE_LIMIT_MAX_REQUESTS=
RATE_LIMIT_WINDOW=

# Vercel/Upstash KV (short URLs, rate limiting)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ZEPL API (shared credentials for all PMs)
ZEPL_API_KEY=
ZEPL_API_BASE=https://api.zepl.io

# Flamingo session
FLAMINGO_SESSION_SECRET=<generate-with-openssl-rand-base64-32>

# Onseason SSO
ONSEASON_BASE_URL=https://app.onseason.ai
ONSEASON_SSO_SECRET=<shared-secret-from-onseason-sso-products-table>
ONSEASON_SSO_CLIENT_ID=flamingo
NEXT_PUBLIC_ONSEASON_BASE_URL=https://app.onseason.ai
NEXT_PUBLIC_ONSEASON_SSO_CLIENT_ID=flamingo

# Neon Postgres — shared builder database (NOT per-customer Payload DBs)
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

### Disabling functionality (when uncommented)

# Disable API key and base URL input in the chat
# NEXT_PUBLIC_NO_API_KEY_INPUT=
# NEXT_PUBLIC_NO_BASE_URL_INPUT=

# Hide local models from the list of available models
# NEXT_PUBLIC_HIDE_LOCAL_MODELS=
